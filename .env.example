# Copy this file to .env for local testing.
# On your hosting provider (Render, Railway, etc.) set these as
# dashboard environment variables instead — don't upload .env itself.

PORT=3000

# Get a free API key at https://resend.com (3,000 emails/month free,
# 100/day). While testing you can send from onboarding@resend.dev
# without verifying your own domain.
RESEND_API_KEY=

# Must match (or be a verified domain on) your Resend account.
# For testing you can leave this as onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# Any long random string — used to authorize the external cron trigger.
# Generate one with: openssl rand -hex 16
CRON_SECRET=changeme

# IANA timezone for the 8am send
TIMEZONE=Australia/Melbourne

# The public URL of this backend once deployed, used to build the
# unsubscribe link in emails, e.g. https://your-app.onrender.com
UNSUBSCRIBE_BASE_URL=http://localhost:3000
